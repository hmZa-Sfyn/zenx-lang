// errors.zx — intentional errors to showcase ZX diagnostics
// Run:  zxc check examples/errors.zx
// Each error has its E-code commented next to it

// E11: type mismatch on init
let score: int = "oops";

// E27: undefined variable
let y = z + 1;

// E32: string concatenation with +
let greeting: str = "hello" + " world";

// E10: cannot infer type — no annotation and no init
let mystery;

// E34: division by zero
let bad: int = 42 / 0;

// E13: const without init
const MISSING_VALUE: float;
